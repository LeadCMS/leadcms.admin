    "@emotion/styled": "^11.10.5",
    "@monaco-editor/react": "^4.7.0",
    "@hookform/resolvers": "^5.0.1",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/x-data-grid": "^8.3.0",
    "@mui/x-date-pickers": "^8.3.0",
